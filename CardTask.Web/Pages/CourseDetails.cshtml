@page "{id:int}"
@model CardTask.Web.Pages.CourseDetailsModel
@using CardTask.Web.Utils
@{
    ViewData["Title"] = @Model.CurrentCourse?.CourseCode;
    ViewData["CachedCourses"] = Model.UserCourses;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<style>
    .flatpickr-day.selected, .flatpickr-day.selected:hover {
        background: #ad0000 !important;
        border-color: #ad0000 !important;
    }

    .flatpickr-months .flatpickr-month {
        background: #212529 !important;
        color: #fff !important;
    }

    .flatpickr-current-month .flatpickr-monthDropdown-months {
        background: #212529 !important;
    }

    .flatpickr-calendar {
        border-radius: 12px !important;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15) !important;
        border: none !important;
    }

    .course-action-btn {
        opacity: 0.6;
        transition: opacity 0.2s ease, transform 0.2s ease;
    }

        .course-action-btn:hover {
            opacity: 1;
            transform: scale(1.1);
        }
</style>

<div class="container-fluid py-2">
    <div class="row mb-4 align-items-center">
        <div class="col-sm-8">
            <a asp-page="/Index" class="text-decoration-none small fw-semibold text-secondary mb-2 d-inline-block">
                <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
            </a>
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <h2 class="fw-bold mb-0 text-dark">@Model.CurrentCourse?.CourseCode</h2>
                <div class="d-flex gap-1">
                    <button type="button" class="btn btn-link p-1 text-secondary course-action-btn" title="Edit Course Details" onclick="openEditCourseModal()">
                        <i class="bi bi-pencil-square fs-5"></i>
                    </button>
                    <button type="button" class="btn btn-link p-1 text-danger course-action-btn" title="Delete Course" onclick="openDeleteCourseModal()">
                        <i class="bi bi-trash3-fill fs-5"></i>
                    </button>
                </div>
            </div>
            <p class="text-muted small mb-0 mt-1">@Model.CurrentCourse?.CourseName</p>
        </div>
        <div class="col-sm-4 text-sm-end mt-3 mt-sm-0">
            <button type="button" class="btn text-white fw-bold rounded-3 py-2 px-4 shadow-sm"
                    style="background-color: #ad0000; border: none;"
                    onclick="openCreateModal()">
                <i class="bi bi-plus-lg me-1"></i> Create New Task
            </button>
        </div>
    </div>

    <div class="row">
        <div class="col-12 mb-4">

            <div class="card border-0 shadow-sm rounded-4 p-2 bg-white mb-4">
                <div class="card-body">
                    <h5 class="fw-bold mb-3 text-dark">
                        <i class="bi bi-list-task me-2 text-danger"></i>Active Task Menu
                    </h5>

                    @if (Model.CurrentCourse?.Tasks != null && Model.CurrentCourse.Tasks.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light text-secondary small text-uppercase">
                                    <tr>
                                        <th>Task Description (Click to Modify / Edit)</th>
                                        <th>Label Tag</th>
                                        <th>Due Date</th>
                                        <th class="text-end">Status Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var task in Model.CurrentCourse.Tasks.OrderBy(t => t.DueDate))
                                    {
                                        <tr class="task-row" style="cursor: pointer;" title="Click to modify task details"
                                            data-id="@task.Id"
                                            data-title="@task.Title"
                                            data-label="@task.Label"
                                            data-duedate="@task.DueDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")">

                                            <td class="clickable-cell">
                                                <span class="fw-semibold @(task.IsCompleted ? "text-muted text-decoration-line-through" : "text-dark")">
                                                    @task.Title
                                                </span>
                                            </td>
                                            <td class="clickable-cell">
                                                <span class="badge rounded-pill px-3 py-1" style="@LabelStyleExtensions.GetLabelStyles(task.Label)">
                                                    @task.Label
                                                </span>
                                            </td>
                                            <td class="text-muted small clickable-cell">
                                                @task.DueDate.ToLocalTime().ToString("MMM dd, yyyy (hh:mm tt)")
                                            </td>
                                            <td class="text-end">
                                                <form method="post" asp-page-handler="ToggleComplete" asp-route-taskId="@task.Id">
                                                    @if (!task.IsCompleted)
                                                    {
                                                        <button type="submit" class="btn btn-sm btn-outline-success rounded-3 px-3">
                                                            <i class="bi bi-check2"></i> Mark Done
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button type="submit" class="btn btn-sm btn-success rounded-3 px-3 shadow-none text-white fw-semibold">
                                                            <i class="bi bi-check-circle-fill me-1"></i> Completed
                                                        </button>
                                                    }
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="display-6 text-muted mb-2"><i class="bi bi-journal-check"></i></div>
                            <p class="text-muted fw-medium mb-0">No tasks added to this course menu yet.</p>
                        </div>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 p-2 bg-white">
                <div class="card-body">
                    <h5 class="fw-bold mb-1 text-dark">
                        <i class="bi bi-tags-fill me-2 text-danger"></i>Manage Course Labels
                    </h5>
                    <p class="text-muted small mb-3">Click a custom category badge to delete it, or use the quick-add tool below.</p>

                    <div class="d-flex flex-wrap gap-2 p-3 bg-light rounded-3 mb-3">
                        @foreach (var label in Model.AvailableLabels)
                        {
                            @if (label == "Assignment")
                            {
                                <span class="badge px-3 py-2 rounded-pill d-flex align-items-center gap-1" style="@LabelStyleExtensions.GetLabelStyles(label)">
                                    <i class="bi bi-pin-angle-fill me-1"></i>@label
                                </span>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="DeleteLabel" class="d-inline">
                                    <input type="hidden" name="LabelToDelete" value="@label" />
                                    <button type="submit" class="badge px-3 py-2 rounded-pill border-0 d-flex align-items-center gap-2 transition-all hover-delete-badge"
                                            style="@LabelStyleExtensions.GetLabelStyles(label)"
                                            title="Click to remove '@label'">
                                        @label <i class="bi bi-x-circle-fill opacity-75"></i>
                                    </button>
                                </form>
                            }
                        }
                    </div>

                    <form method="post" asp-page-handler="AddLabel">
                        <div class="row g-2">
                            <div class="col-sm-8 col-md-6">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-tag"></i></span>
                                    <input asp-for="CustomLabelName" class="form-control rounded-end-3 form-control-sm border-start-0" placeholder="Type new label name..." required maxlength="20" />
                                </div>
                            </div>
                            <div class="col-sm-4 col-md-3">
                                <button type="submit" class="btn btn-dark btn-sm rounded-3 px-3 fw-bold w-100 h-100">
                                    <i class="bi bi-plus-lg me-1"></i> Create Label
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@* Primary Task Creation Modal *@
<div class="modal fade" id="taskControlModal" data-bs-backdrop="static" tabindex="-1" aria-labelledby="modalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 460px;">
        <div class="modal-content border-0 shadow-lg rounded-4 p-2">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold text-dark mb-0" id="modalTitle">Create New Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form method="post" asp-page-handler="AddTask" id="modalForm">
                    <input type="hidden" asp-for="EditingTaskId" id="modalTaskId" value="0" />

                    <div class="mb-3">
                        <label asp-for="NewTaskTitle" class="form-label small fw-semibold text-secondary">Task Title / Details</label>
                        <input asp-for="NewTaskTitle" id="modalTaskTitle" class="form-control rounded-3" placeholder="e.g., Complete Operating Systems Lab 2" required maxlength="200" />
                        <span asp-validation-for="NewTaskTitle" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewTaskLabel" class="form-label small fw-semibold text-secondary">Category Label Tag</label>
                        <select asp-for="NewTaskLabel" id="modalTaskLabel" class="form-select rounded-3">
                            @foreach (var label in Model.AvailableLabels)
                            {
                                <option value="@label">@label</option>
                            }
                        </select>
                        <span asp-validation-for="NewTaskLabel" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="NewTaskDueDate" class="form-label small fw-semibold text-secondary">Deadlines & Due Date</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white text-muted border-end-0 rounded-start-3"><i class="bi bi-calendar3"></i></span>
                            <input asp-for="NewTaskDueDate" id="modalTaskDueDate" type="text" class="form-control bg-white rounded-end-3" placeholder="Select deadline date & time..." required />
                        </div>
                        <span asp-validation-for="NewTaskDueDate" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-light rounded-3 py-2 w-50 fw-semibold text-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" id="modalSubmitBtn" class="btn text-white w-50 fw-bold rounded-3 py-2 shadow-sm" style="background-color: #ad0000; border: none;">
                            Add Course Task
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* Edit Course Name/Code Modal Container Template *@
<div class="modal fade" id="editCourseModal" data-bs-backdrop="static" tabindex="-1" aria-labelledby="editCourseModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 460px;">
        <div class="modal-content border-0 shadow-lg rounded-4 p-2">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold text-dark mb-0" id="editCourseModalTitle">Modify Course Information</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form method="post" asp-page-handler="EditCourse" asp-route-id="@Model.CurrentCourse!.Id" id="editCourseForm">
                    <div class="mb-3">
                        <label asp-for="CourseUpdate.CourseCode" class="form-label small fw-semibold text-secondary">Course Code</label>
                        <input type="text" asp-for="CourseUpdate.CourseCode" id="editCourseCode" class="form-control rounded-3" required maxlength="15" />
                        <span asp-validation-for="CourseUpdate.CourseCode" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="CourseUpdate.CourseName" class="form-label small fw-semibold text-secondary">Full Course Name</label>
                        <input type="text" asp-for="CourseUpdate.CourseName" id="editCourseName" class="form-control rounded-3" required maxlength="100" />
                        <span asp-validation-for="CourseUpdate.CourseName" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-light rounded-3 py-2 w-50 fw-semibold text-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn text-white w-50 fw-bold rounded-3 py-2 shadow-sm" style="background-color: #ad0000; border: none;">
                            Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* Delete Course Confirmation Modal Template *@
<div class="modal fade" id="deleteCourseModal" tabindex="-1" aria-labelledby="deleteCourseModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content border-0 shadow-lg rounded-4 p-2">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold text-dark mb-0" id="deleteCourseModalTitle">Remove Course</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
                <p class="text-secondary small mb-4">
                    Are you sure you want to permanently delete <strong class="text-dark">@Model.CurrentCourse?.CourseCode</strong>? This will erase all connected data points and lists. This sweep cannot be reverted.
                </p>
                <form method="post" asp-page-handler="DeleteCourse" id="deleteCourseForm">
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-light rounded-3 py-2 w-50 fw-semibold text-secondary" data-bs-dismiss="modal">Dismiss</button>
                        <button type="submit" class="btn btn-danger w-50 fw-bold rounded-3 py-2 shadow-sm">
                            Confirm Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

    <script>
        const datePickerInstance = flatpickr("#modalTaskDueDate", {
        enableTime: true,
        dateFormat: "Y-m-d H:i",
        altInput: true,
        altFormat: "F j, Y - h:i K",
        minDate: "today",
        time_24hr: false
        });

        const bootstrapModal = new bootstrap.Modal(document.getElementById('taskControlModal'));
        const editCourseModal = new bootstrap.Modal(document.getElementById('editCourseModal'));
        const deleteCourseModal = new bootstrap.Modal(document.getElementById('deleteCourseModal'));

        const mTitle = document.getElementById('modalTitle');
        const mSubmitBtn = document.getElementById('modalSubmitBtn');
        const mTaskId = document.getElementById('modalTaskId');
        const mTaskTitle = document.getElementById('modalTaskTitle');
        const mTaskLabel = document.getElementById('modalTaskLabel');

        function openCreateModal() {
        mTaskId.value = "0";
        mTaskTitle.value = "";
        mTaskLabel.selectedIndex = 0;

        const defaultDate = new Date();
        defaultDate.setDate(defaultDate.getDate() + 7);
        datePickerInstance.setDate(defaultDate);

        mTitle.innerText = "Create New Task";
        mSubmitBtn.innerText = "Add Course Task";

        bootstrapModal.show();
        }

        function openEditCourseModal() {
        editCourseModal.show();
        }

        function openDeleteCourseModal() {
        deleteCourseModal.show();
        }

        document.addEventListener("DOMContentLoaded", function() {
        document.querySelectorAll(".clickable-cell").forEach(cell => {
        cell.addEventListener("click", function() {
        const row = this.closest(".task-row");

        mTaskId.value = row.getAttribute("data-id");
        mTaskTitle.value = row.getAttribute("data-title");
        mTaskLabel.value = row.getAttribute("data-label");

        const rawDateString = row.getAttribute("data-duedate");
        datePickerInstance.setDate(rawDateString);

        mTitle.innerText = "Modify Task Details";
        mSubmitBtn.innerText = "Save Adjustments";

        bootstrapModal.show();
        });
        });
        });
    </script>
}