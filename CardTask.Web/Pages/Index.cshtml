@page
@model CardTask.Web.Pages.IndexModel
@using CardTask.Web.Utils
@{
    ViewData["Title"] = "Dashboard Workspace";
    ViewData["CachedCourses"] = Model.UserCourses;
}

<div class="container-fluid py-2">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold mb-1 text-dark">Welcome back, @User.Identity?.Name!</h2>
            <p class="text-muted small">Manage your University of Louisville courses and assignments in real-time.</p>
        </div>
    </div>

    <div class="row">
        
        <div class="col-lg-8 mb-4">
            <div class="card border-0 shadow-sm rounded-4 p-2 bg-white">
                <div class="card-body">
                    <h5 class="fw-bold mb-3 text-dark">
                        <i class="bi bi-calendar-check me-2 text-danger"></i>Upcoming Tasks & Assignments
                    </h5>

                    <div class="mb-4 d-flex gap-2 flex-wrap align-items-center">
                        <small class="text-secondary fw-semibold text-uppercase me-1" style="font-size: 0.75rem;">Filter Tasks:</small>
                        
                        <a asp-page="./Index" 
                           class="btn btn-sm rounded-pill px-3 @(string.IsNullOrEmpty(Model.ActiveLabelFilter) ? "btn-dark text-white" : "btn-outline-secondary")">
                            All
                        </a>

                        @foreach (var labelName in Model.AvailableCustomLabels)
                        {
                            bool isActive = Model.ActiveLabelFilter.Equals(labelName, StringComparison.OrdinalIgnoreCase);
                            
                            <a asp-page="./Index" 
                               asp-route-labelFilter="@labelName" 
                               class="btn btn-sm rounded-pill px-3 @(isActive ? "btn-danger text-white" : "btn-outline-secondary")">
                                @labelName
                            </a>
                        }
                    </div>

                    @if (Model.UpcomingTasks.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light text-secondary small text-uppercase">
                                    <tr>
                                        <th>Task / Assignment</th>
                                        <th>Category</th>
                                        <th>Due Date</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var task in Model.UpcomingTasks)
                                    {
                                        <tr>
                                            <td>
                                                <span class="fw-semibold text-dark">@task.Title</span>
                                            </td>
                                            <td>
                                                <span class="badge rounded-pill px-3 py-1" style="@LabelStyleExtensions.GetLabelStyles(task.Label)">
                                                    @task.Label
                                                </span>
                                            </td>
                                            <td class="text-muted small">
                                                @task.DueDate.ToLocalTime().ToString("MMM dd, yyyy (hh:mm tt)")
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-success rounded-3 px-3">
                                                    <i class="bi bi-check2"></i> Complete
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="display-6 text-muted mb-2"><i class="bi bi-clipboard-check"></i></div>
                            <p class="text-muted fw-medium mb-0">All clear! No pending tasks due soon.</p>
                        </div>
                    }
                </div>
            </div>
        </div> <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-2">
                <div class="card-body">
                    <h5 class="fw-bold mb-1 text-dark">
                        <i class="bi bi-plus-circle me-2 text-danger"></i>Quick Add Course
                    </h5>
                    <p class="text-muted small mb-4">Register a new tracking target to your local profile engine.</p>

                    <form method="post" asp-page-handler="AddCourse">
                        <div class="mb-3">
                            <label asp-for="NewCourseCode" class="form-label small fw-semibold text-secondary">Course Code</label>
                            <input asp-for="NewCourseCode" class="form-control rounded-3" placeholder="e.g., CSE 350" required maxlength="10" />
                            <span asp-validation-for="NewCourseCode" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="NewCourseName" class="form-label small fw-semibold text-secondary">Course Name</label>
                            <input asp-for="NewCourseName" class="form-control rounded-3" placeholder="e.g., Operating Systems" required maxlength="100" />
                            <span asp-validation-for="NewCourseName" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn text-white w-100 fw-bold rounded-3 py-2 shadow-sm" style="background-color: #ad0000; border: none;">
                            <i class="bi bi-folder-plus me-1"></i> Add to Profile
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}