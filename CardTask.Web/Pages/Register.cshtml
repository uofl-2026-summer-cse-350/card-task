@page
@model CardTask.Web.Pages.RegisterModel
@{
    ViewData["Title"] = "Create Account";
    Layout = null; // Decouples this view completely from the global sidebar shell
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CardTask</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body style="background-color: #f8f9fa;">

    <div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="card border-0 shadow-lg p-3 rounded-4" style="width: 100%; max-width: 420px; background-color: #ffffff;">
            <div class="card-body">
                <h3 class="text-center fw-bold mb-1" style="color: #ad0000;">CardTask</h3>
                <p class="text-muted text-center small mb-4">UofL Student Registration Portal</p>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small p-2 mb-3 rounded-3" style="background-color: #fff5f5;"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold text-secondary small">University Email</label>
                        <input asp-for="Email" type="email" class="form-control form-control-lg rounded-3 border-secondary-subtle fs-6" placeholder="username@louisville.edu" autocomplete="username" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold text-secondary small">Secure Password</label>
                        <input asp-for="Password" type="password" class="form-control form-control-lg rounded-3 border-secondary-subtle fs-6" placeholder="••••••••" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-lg w-100 fw-bold text-white rounded-3 shadow-sm mb-3 py-2" style="background-color: #ad0000; border: none;">
                        Create Profile
                    </button>
                </form>

                <div class="text-center pt-2 border-top border-light-subtle">
                    <p class="small text-muted mb-0">Already registered? <a asp-page="/Login" class="fw-semibold text-decoration-none" style="color: #ad0000;">Sign In</a></p>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>