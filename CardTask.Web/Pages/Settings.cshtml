@page
@model CardTask.Web.Pages.SettingsModel
@{
    ViewData["Title"] = "Settings & Diagnostics";
    // Pass live data down to your layout sidebar menu loop
    ViewData["CachedCourses"] = Model.UserCourses;
}

<div class="container-fluid py-2">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold mb-1 text-dark">⚙️ Control Panel & Settings</h2>
            <p class="text-muted small">Manage your student profile, security credentials, and system database engine metrics.</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-7 mb-4">
            <div class="card border-0 shadow-sm rounded-4 p-2 bg-white">
                <div class="card-body">
                    <h5 class="fw-bold mb-1 text-dark">
                        <i class="bi bi-shield-lock-fill me-2 text-danger"></i>Update Security Credentials
                    </h5>
                    <p class="text-muted small mb-4">Change your authentication keys safely inside the system database layer.</p>

                    <form method="post" asp-page-handler="ChangePassword">
                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-secondary">Active Student Identity</label>
                            <input class="form-control rounded-3 bg-light text-muted" value="@User.Identity?.Name" readonly disabled />
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label small fw-semibold text-secondary">New Secure Password</label>
                            <input asp-for="NewPassword" type="password" class="form-control rounded-3" placeholder="••••••••" required />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label small fw-semibold text-secondary">Confirm Password</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control rounded-3" placeholder="••••••••" required />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-dark fw-bold rounded-3 px-4 shadow-sm">
                            <i class="bi bi-save me-1"></i> Commit New Hash
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5 mb-4">
            <div class="card border-0 shadow-sm rounded-4 p-2 bg-white mb-4">
                <div class="card-body">
                    <h5 class="fw-bold mb-1 text-dark">
                        <i class="bi bi-cpu-fill me-2 text-danger"></i>System Diagnostics
                    </h5>
                    <p class="text-muted small mb-4">Real-time object mapping metrics for your LocalDB hardware instance.</p>

                    <div class="list-group list-group-flush small mb-2">
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
                            <span class="text-secondary fw-semibold"><i class="bi bi-folder-fill me-2"></i>Total Courses Logged</span>
                            <span class="badge bg-secondary-subtle text-secondary rounded-pill font-monospace px-3 py-1 fs-6">@Model.TotalCoursesCount</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
                            <span class="text-secondary fw-semibold"><i class="bi bi-hourglass-split me-2"></i>Pending Tasks Tracked</span>
                            <span class="badge bg-danger-subtle text-danger rounded-pill font-monospace px-3 py-1 fs-6">@Model.PendingTasksCount</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
                            <span class="text-secondary fw-semibold"><i class="bi bi-check-all me-2"></i>Archived Completed Tasks</span>
                            <span class="badge bg-success-subtle text-success rounded-pill font-monospace px-3 py-1 fs-6">@Model.CompletedTasksCount</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 p-2 bg-white">
                <div class="card-body">
                    <h5 class="fw-bold mb-1 text-dark">
                        <i class="bi bi-wrench-adjustable me-2 text-dark"></i>Maintenance Actions
                    </h5>
                    <p class="text-muted small mb-4">Utility shortcuts for project presentation evaluations.</p>

                    <form method="post" asp-page-handler="ResetDatabase" onsubmit="return confirm('⚠️ CardTask Warning:\n\nAre you completely sure you want to drop all courses and tasks associated with your account out of the local database? This cannot be undone.');">
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100 fw-bold rounded-3 py-2">
                            <i class="bi bi-trash3-fill me-1"></i> Purge Profile Data
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}