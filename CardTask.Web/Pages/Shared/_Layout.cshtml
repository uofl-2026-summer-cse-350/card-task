<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CardTask.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CardTask.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">CardTask.Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    @* Sidebar into a flexbox *@
    <div class="d-flex">
        @* Fixed sidebar *@
        <nav class="bg-dark text-white p-3 d-flex flex-column" style="width: 250px; min-height: calc(100vh - 56px);">
            <div class="mb-4 px-2">
                <h5 class="text-white fw-bold">
                    <i class="bi bi-list me-2"></i>Navigation
                </h5>
                <hr class="text-secondary" />
            </div>

            <ul class="nav flex-column mb-auto">
                <li class="nav-item mb-1">
                    <a class="nav-link text-white rounded px-3 py-2 @(Context.Request.Path == "/Index" ? "bg-secondary" : "")"
                       asp-page="/Index">
                        <i class="bi bi-grid-1x2-fill me-2"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item mb-1">
                    <a class="nav-link text-white rounded px-3 py-2 @(Context.Request.Path == "/Settings" ? "bg-secondary" : "")"
                       asp-page="/Settings">
                        <i class="bi bi-gear-fill me-2"></i>Settings
                    </a>
                </li>
            </ul>
            @* My Courses section, alongside course scaffolding for actual data later. Swap <li> tags for a loop connecting to the user's courses.*@
            <div class="mt-4 mb-3">
                <h6 class="text-uppercase text-secondary fw-bold px-2 mb-2">
                    <i class="bi bi-book-fill me-1"></i>My Courses
                </h6>
                <ul class="nav flex-column">
                    <li class="nav-item mb-1">
                        <a class="nav-link text-white-50 rounded px-3 py-2" href="#">
                            <i class="bi bi-bookmark-fill me-2"></i>Course 1
                        </a>
                    </li>
                    <li class="nav-item mb-1">
                        <a class="nav-link text-white-50 rounded px-3 py-2" href="#">
                            <i class="bi bi-bookmark-fill me-2"></i>Course 2
                        </a>
                    </li>
                    <li class="nav-item mb-1">
                        <a class="nav-link text-white-50 rounded px-3 py-2" href="#">
                            <i class="bi bi-bookmark-fill me-2"></i>Course 3
                        </a>
                    </li>
                </ul>
            </div>

            @* Sidebar Footer Actions with Dynamic Sign Out *@
            <div class="mt-auto pt-3 border-top border-secondary">
                <a class="nav-link text-white-50 px-3 py-2 mb-3" asp-page="/Privacy">
                    <i class="bi bi-shield-lock me-2"></i>Privacy
                </a>

                <a class="btn btn-danger btn-sm w-100 fw-bold rounded-3 py-2 text-white shadow-sm"
                   asp-page="/Logout"
                   style="background-color: #ad0000; border: none;">
                    <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                </a>
            </div>
        </nav>

        <main class="flex-grow-1 p-4" style="background-color: #f8f9fa;">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CardTask.Web - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>