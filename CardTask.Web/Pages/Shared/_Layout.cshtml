<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CardTask.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CardTask.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        /* Forces the main browser body window context to never scroll or stretch artificially */
        html, body {
        margin: 0 !important;
        padding: 0 !important;
        height: 100% !important;
        overflow: hidden !important;
        }
    </style>
</head>
<body>

    @* Sidebar into a flexbox *@
    <div class="d-flex" style="height: 100vh; width: 100vw;">
        @* Fixed sidebar *@
        <nav class="bg-dark text-white p-3 d-flex flex-column h-100" style="width: 250px; min-width: 250px;">
            <div class="mb-4 px-2">
                <h5 class="text-white fw-bold">
                    <i class="bi bi-list me-2"></i>Navigation
                </h5>
                <hr class="text-secondary" />
            </div>

            <ul class="nav flex-column mb-auto">
                <li class="nav-item mb-1">
                    <a class="nav-link text-white rounded px-3 py-2 @(Context.Request.Path == "/Index" ? "bg-secondary" : "")"
                       asp-page="/Index">
                        <i class="bi bi-grid-1x2-fill me-2"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item mb-1">
                    <a class="nav-link text-white rounded px-3 py-2 @(Context.Request.Path == "/Settings" ? "bg-secondary" : "")"
                       asp-page="/Settings">
                        <i class="bi bi-gear-fill me-2"></i>Settings
                    </a>
                </li>
            </ul>
            @* My Courses section, alongside course scaffolding for actual data later. Swap <li> tags for a loop connecting to the user's courses.*@
            <div class="mt-4 mb-3" style="overflow-y: auto; max-height: 50vh;">
                <h6 class="text-uppercase text-secondary fw-bold px-2 mb-2">
                    <i class="bi bi-book-fill me-1"></i>My Courses
                </h6>
                <ul class="nav flex-column">
                    @if (ViewData["CachedCourses"] is List<CardTask.Core.Models.Course> activeCourses && activeCourses.Any())
                    {
                        @foreach (var course in activeCourses)
                        {
                            <li class="nav-item mb-1">
                                <a class="nav-link text-white-50 rounded px-3 py-2 d-flex justify-content-between align-items-center"
                                   asp-page="/CourseDetails" asp-route-id="@course.Id">
                                    <span>
                                        <i class="bi bi-bookmark-fill me-2 text-danger"></i>@course.CourseCode
                                    </span>
                                    <span class="badge bg-secondary rounded-pill small">
                                        @course.Tasks.Count(t => !t.IsCompleted)
                                    </span>
                                </a>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="nav-item px-3 py-2 text-muted small italic">
                            <i class="bi bi-info-circle me-1"></i>No courses added.
                        </li>
                    }
                </ul>
            </div>

            @* Sidebar Footer Actions with Dynamic Sign Out *@
            <div class="mt-auto pt-3 border-top border-secondary">
                <a class="btn btn-danger btn-sm w-100 fw-bold rounded-3 py-2 text-white shadow-sm"
                   asp-page="/Logout"
                   style="background-color: #ad0000; border: none;">
                    <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                </a>
            </div>
        </nav>

        <main class="flex-grow-1 p-4 d-flex flex-column justify-content-between h-100" style="background-color: #f8f9fa; overflow-y: auto;">
            <div class="container-fluid mb-4">
                @RenderBody()
            </div>

            <footer class="container-fluid border-top pt-3 mt-auto text-secondary flex-shrink-0">
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2" style="font-size: 0.8rem;">
                    <div>
                        <span class="fw-bold text-dark">CardTask Project</span> &copy; 2026
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <span><i class="bi bi-mortarboard-fill me-1"></i> CSE 350 Software Engineering</span>
                        <span class="text-muted">|</span>
                        <span><i class="bi bi-people-fill me-1"></i> Group 10</span>
                    </div>
                </div>
            </footer>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)</body>
</html>